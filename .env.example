# ═══════════════════════════════════════
# SENTINEX v2.0 — Environment Configuration
# ═══════════════════════════════════════

# Anthropic API
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_MODEL=claude-sonnet-4-5

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=sentinex-agent-cluster

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=sentinex123

# ChromaDB
CHROMADB_HOST=localhost
CHROMADB_PORT=8001

# Redis
REDIS_URL=redis://localhost:6379/0

# Firewall Stubs
PFSENSE_API_URL=http://localhost:9999/api/pfsense
CLOUDFLARE_API_TOKEN=stub_token

# Application
LOG_LEVEL=INFO
ENVIRONMENT=development

# Agent Configuration
THREAT_SCORE_THRESHOLD=0.55
SOC_ANALYST_MAX_ROUNDS=3
SOC_ANALYST_CONFIDENCE_THRESHOLD=85
AUTONOMOUS_RESPONSE_ENABLED=true
HITL_IRREVERSIBILITY_THRESHOLD=0.8

# Frontend
FRONTEND_URL=http://localhost:5173
DEMO_MODE=true
